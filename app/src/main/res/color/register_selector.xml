<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cuando está presionado o en hover -->
    <item android:state_pressed="true" android:color="#87CEEB"/>
    <item android:state_focused="true" android:color="#87CEEB"/>
