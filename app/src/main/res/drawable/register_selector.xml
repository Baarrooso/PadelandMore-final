<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cuando está presionado -->
    <item android:state_pressed="true" android:color="#87CEEB"/>
    <!-- Cuando está seleccionado, hover o focus -->
    <item android:state_focused="true" android:color="#87CEEB"/>
    <!-- Estado normal -->
    <item android:color="#FFFFFF"/>
</selector>
