<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/dark_blue</item>
        <item name="colorAccent">@color/accent_orange</item>
        <item name="android:background">@color/dark_blue</item>
    </style>

    <!-- Estilo para botones Playtomic -->
    <style name="PlaytomicButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:background">@color/primary_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Estilo para botones de acción (Reservar, etc) -->
    <style name="PlaytomicActionButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@color/accent_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>

