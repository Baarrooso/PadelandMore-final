<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_evento_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgUsuarioComunidad"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/circle_mask"
        android:scaleType="centerCrop"
        android:src="@drawable/userlogo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreUsuarioComunidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMetaUsuarioComunidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/light_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtSeguidoresUsuarioComunidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/accent_orange"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSeguirUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:minWidth="96dp"
        android:text="@string/seguir"
        android:textAllCaps="false"
        android:backgroundTint="@color/accent_orange"
        android:textColor="@color/white" />
</LinearLayout>

