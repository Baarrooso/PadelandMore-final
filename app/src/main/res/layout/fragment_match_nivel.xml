<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/primary_blue">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:text="Buscar Jugadores"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtNivelBuscado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nivel buscado: 3"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seekNivelBuscado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6"
            android:progress="2" />

        <EditText
            android:id="@+id/edtCiudadBuscada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ciudad (opcional)" />

        <Button
            android:id="@+id/btnBuscarNivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Buscar"
            android:backgroundTint="@color/primary_blue"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/listJugadoresNivel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp" />

</LinearLayout>

