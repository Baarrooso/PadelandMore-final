<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header Mejorado -->
    <LinearLayout
        android:id="@+id/headerReservas"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_header"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="normal"
            android:alpha="0.9" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Padel and More"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎾 Reserva tus clases y pistas"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:alpha="0.85" />

    </LinearLayout>

    <!-- ScrollView para todo el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Botones Sorteos y Torneos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnSorteosReserva"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Sorteos"
                    android:backgroundTint="@color/accent_orange"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnTorneosReserva"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Torneos"
                    android:backgroundTint="@color/accent_orange"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- Pistas Disponibles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pistas Disponibles"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <!-- Pista 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pista 1 - Central"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Club Padel Madrid"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarPista1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Pista 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pista 2 - Lateral"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Club Padel Madrid"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarPista2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="#00C853"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Pista 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pista 3 - Premium"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Club Padel Alcalá"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarPista3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="#00C853"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Pista 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pista 4 - Indoor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Club Padel Getafe"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarPista4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </LinearLayout>

            <!-- Clases Disponibles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clases Disponibles"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="12dp" />

                <!-- Clase 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clase de Iniciación"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lunes y Miércoles - 10:00"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarClase1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Clase 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clase de Nivel Intermedio"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Martes y Jueves - 14:00"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarClase2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Clase 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clase de Avanzado"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Miércoles y Viernes - 18:00"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarClase3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

                <!-- Clase 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_evento_card"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Taller de Técnica"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sábados - 11:00"
                            android:textSize="12sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnReservarClase4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservar"
                        android:backgroundTint="@color/accent_orange"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>

