<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_blue_light"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Soporte"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escríbenos y te ayudamos con cualquier problema."
        android:textColor="@color/white"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/txtSoporteEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="soporte@tmanager.com"
        android:textStyle="bold"
        android:textColor="@color/accent_orange"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnContactarSoporte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Contactar por correo" />

</LinearLayout>

